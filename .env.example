# APGI Framework Environment Configuration
# Copy this file to .env and fill in the values

# Application Settings
APGI_ENV=development
APGI_DEBUG=true
APGI_LOG_LEVEL=DEBUG

# Database Settings
APGI_DB_PATH=data/apgi.db
APGI_DB_BACKUP_PATH=data/backups/

# GUI Settings
APGUI_THEME=dark
APGUI_FONT_SIZE=12
APGUI_WINDOW_WIDTH=1400
APGUI_WINDOW_HEIGHT=900

# Security Settings
APGI_SECRET_KEY=your-secret-key-here-replace-with-random-64-char-hex
APGI_SESSION_TIMEOUT=3600

# Performance Settings
APGI_MAX_WORKERS=4
APGI_THREAD_POOL_SIZE=8
APGI_MEMORY_LIMIT=2g

# Data Paths
APGI_DATA_DIR=data
APGI_OUTPUTS_DIR=apgi_output
APGI_SESSIONS_DIR=session_state
APGI_LOGS_DIR=logs

# External Service URLs (if applicable)
# APGI_EEG_SERVICE_URL=http://eeg-service:8080
# APGI_PUPILLOMETRY_SERVICE_URL=http://pupillometry-service:8081

# Monitoring
APGI_METRICS_ENABLED=true
APGI_HEALTH_CHECK_INTERVAL=30
